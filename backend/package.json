{
  "name": "smart-exam-web-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/scripts/seed.ts",

    "test": "jest -c jest.config.cjs",
    "test:watch": "jest -c jest.config.cjs --watch",
    "test:seatAllocator": "jest -c jest.config.cjs __tests__/utils/seatAllocator.test.ts",
    "test:qr": "jest -c jest.config.cjs __tests__/utils/qr.test.ts",
    "test:student": "jest -c jest.config.cjs __tests__/controllers/student.controller.test.ts",
    "test:hall": "jest -c jest.config.cjs __tests__/controllers/hall.controller.test.ts",
    "test:exam": "jest -c jest.config.cjs __tests__/controllers/exam.controller.test.ts",
    "test:attendance": "jest -c jest.config.cjs __tests__/controllers/attendance.controller.test.ts",
    "test:dashboard": "jest -c jest.config.cjs __tests__/controllers/dashboard.controller.test.ts",
    "test:reports": "jest -c jest.config.cjs __tests__/controllers/reports.controller.test.ts",

    "test:integration": "jest -c jest.integration.config.cjs --runInBand",
    "test:int:auth": "jest -c jest.integration.config.cjs --runInBand __tests__/integration/auth.integration.test.ts",
    "test:int:students": "jest -c jest.integration.config.cjs --runInBand __tests__/integration/students.integration.test.ts",
    "test:int:halls": "jest -c jest.integration.config.cjs --runInBand __tests__/integration/halls.integration.test.ts",
    "test:int:exams": "jest -c jest.integration.config.cjs --runInBand __tests__/integration/exams.integration.test.ts",
    "test:int:allocations": "jest -c jest.integration.config.cjs --runInBand __tests__/integration/allocations.integration.test.ts",
    "test:int:attendance": "jest -c jest.integration.config.cjs --runInBand __tests__/integration/attendance.integration.test.ts",
    "test:int:dashboard": "jest -c jest.integration.config.cjs --runInBand __tests__/integration/dashboard.integration.test.ts",
    "test:int:reports": "jest -c jest.integration.config.cjs --runInBand __tests__/integration/reports.integration.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@jest/globals": "29.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "jest-cli": "29.7.0",
    "jest-util": "29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3"
  }
}